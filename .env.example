POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres
PQDB_PLATFORM_DB=pqdb_platform
VAULT_DEV_ROOT_TOKEN_ID=dev-root-token
VAULT_ADDR=http://vault:8200

# Base URL for the pqdb API (via Caddy HTTPS reverse proxy)
PQDB_BASE_URL=https://localhost

# Trust Caddy's internal CA for Node.js processes (SDK, MCP server, dashboard).
# Run infra/init-scripts/trust-caddy-ca.sh first to extract the CA certificate.
# NODE_EXTRA_CA_CERTS=infra/caddy-root-ca.crt
