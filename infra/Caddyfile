{
	# Use Caddy's internal CA for local dev TLS certificates.
	# Go 1.24+ negotiates X25519MLKEM768 by default — no explicit PQC config needed.
}

localhost {
	tls internal

	# Backend API — runs on the host (not in Docker) for hot-reload
	handle /v1/* {
		reverse_proxy host.docker.internal:8000
	}

	handle /health {
		reverse_proxy host.docker.internal:8000
	}

	handle /ready {
		reverse_proxy host.docker.internal:8000
	}

	# Dashboard (default) — runs on the host for HMR
	handle {
		reverse_proxy host.docker.internal:3000
	}
}
