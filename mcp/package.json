{
  "name": "@pqdb/mcp",
  "version": "0.1.0",
  "description": "MCP server for pqdb — AI agents connect to post-quantum encrypted databases",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "pqdb-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "@pqdb/client": "*",
    "express": "4.21.2"
  },
  "devDependencies": {
    "@types/express": "5.0.1",
    "@types/node": "22.13.14",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsup": "8.4.0",
    "typescript": "5.7.3",
    "vitest": "3.0.9"
  }
}
